digraph user_privilege_model {
    label="User Identity and Privilege Model"
    labelloc="t"
    rankdir=TB
    node [shape=ellipse, style=filled, fillcolor=mintcream]

    root [label="root (UID 0)", fillcolor=lightcoral, shape=octagon]
    dockerd [label="dockerd", shape=box, fillcolor=lightgray]
    
    subgraph cluster_groups {
        label="System Groups"
        color=gray
        sudo_grp [label="sudo (GID 27)", shape=box]
        docker_grp [label="docker", shape=box]
        adm_grp [label="adm", shape=box]
        users_grp [label="users (GID 100)", shape=box]
    }

    subgraph cluster_users {
        label="Standard Users"
        color=blue
        jeb [label="jeb (UID 1000)"]
        www_data [label="www-data"]
        nobody [label="nobody"]
    }

    subgraph cluster_daemons {
        label="Service Execution"
        color=purple
        gemini [label="Gemini Agent Process"]
        nginx_worker [label="NGINX Workers"]
    }

    jeb -> sudo_grp [label="Member"]
    jeb -> docker_grp [label="Member"]
    jeb -> adm_grp [label="Member"]
    
    sudo_grp -> root [label="Escalation (su/sudo)", style=dashed]

    jeb -> gemini [label="Owns"]
    www_data -> nginx_worker [label="Owns"]
    root -> dockerd [label="Owns"]
}
