digraph filesystem_hierarchy {
    label="Filesystem Mount Points & FHS"
    labelloc="t"
    rankdir=TB
    node [shape=folder, style=filled, fillcolor=lightcyan]

    root [label="/ (nvme1n1p1)"]
    boot_efi [label="/boot/efi (nvme1n1p2)"]
    mnt [label="/mnt"]
    
    samsung_ssd [label="/mnt/samsung_ssd (sda1)"]
    sda1_mount [label="/mnt/sda1 (sdc1)"]
    hitachi [label="/mnt/hitachi_2tb (sde1)"]
    raid0 [label="/mnt/raid0 (md0)"]
    sdf1_mount [label="/mnt/sdf1 (sdd1)"]

    usr [label="/usr"]
    var [label="/var"]
    home [label="/home"]
    etc [label="/etc"]
    
    jeb [label="/home/jeb"]
    workspace [label="gemini_cli_workspace"]

    root -> boot_efi
    root -> mnt
    root -> usr
    root -> var
    root -> home
    root -> etc

    mnt -> samsung_ssd
    mnt -> sda1_mount
    mnt -> hitachi
    mnt -> raid0
    mnt -> sdf1_mount

    home -> jeb
    jeb -> workspace
}
