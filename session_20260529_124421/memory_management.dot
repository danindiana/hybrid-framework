digraph memory_management {
    label="Memory Management & Virtualization"
    labelloc="t"
    rankdir=TB
    node [shape=box, style=filled, fillcolor=mistyrose]

    subgraph cluster_app {
        label="Application Process"
        color=blue
        virt_mem [label="Virtual Memory Address Space", shape=cylinder]
        heap [label="Heap / BSS / Data"]
        stack [label="Stack"]
        virt_mem -> heap
        virt_mem -> stack
    }

    mmu [label="CPU Memory Management Unit (MMU)", shape=component, fillcolor=lightyellow]
    page_tables [label="Page Tables (OS Maintained)", fillcolor=white]

    subgraph cluster_physical {
        label="Physical Hardware"
        color=red
        ram [label="Physical RAM (125 GiB)\nPage Frames", shape=cylinder, fillcolor=lightgreen]
        swap [label="Swap Space (0 Bytes)\n(Disabled on this host)", shape=cylinder, fillcolor=lightgray]
    }
    
    page_cache [label="VFS Page Cache\n(File I/O Buffers)"]

    virt_mem -> mmu [label="Virtual Addresses"]
    mmu -> page_tables [label="TLB Miss / Lookup"]
    page_tables -> ram [label="Maps to Physical"]
    
    ram -> page_cache [label="Reserved for"]
    page_cache -> swap [style=dashed, label="Swapping (N/A here)"]
}
