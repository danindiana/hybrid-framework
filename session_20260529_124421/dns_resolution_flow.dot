digraph dns_resolution_flow {
    label="DNS Resolution Flow"
    labelloc="t"
    rankdir=LR
    node [shape=ellipse, style=filled, fillcolor=honeydew]

    app [label="Application\n(e.g., curl, node)", shape=box]
    glibc [label="glibc\n(gethostbyname)", shape=box]
    nsswitch [label="/etc/nsswitch.conf", shape=note]
    hosts_file [label="/etc/hosts", shape=note]
    resolv_conf [label="/etc/resolv.conf", shape=note]
    
    systemd_resolved [label="systemd-resolved\n(127.0.0.53:53)", shape=component, fillcolor=lightblue]
    
    external_dns [label="External DNS\n(e.g., 1.1.1.1, 8.8.8.8)", shape=cloud, fillcolor=lightgray]

    app -> glibc
    glibc -> nsswitch [label="Checks config"]
    
    nsswitch -> hosts_file [label="files"]
    nsswitch -> resolv_conf [label="dns"]
    
    resolv_conf -> systemd_resolved [label="Stub Resolver"]
    
    systemd_resolved -> external_dns [label="Forward Query"]
    
    hosts_file -> app [label="Hit", style=dashed]
    external_dns -> systemd_resolved [label="Response", style=dashed]
    systemd_resolved -> glibc [label="Response", style=dashed]
}
