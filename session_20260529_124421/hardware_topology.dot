digraph hardware_topology {
    label="Hardware Topology"
    labelloc="t"
    rankdir=LR
    node [shape=box, style=filled, fillcolor=lightgray]

    System [label="Ubuntu 22.04.5 LTS Server", shape=ellipse, fillcolor=lightblue]
    
    subgraph cluster_cpu {
        label="CPU"
        color=blue
        CPU [label="AMD Ryzen 9 5950X\n16 Cores / 32 Threads\nMax: 3.4 GHz"]
        L1 [label="L1 Cache: 1 MiB"]
        L2 [label="L2 Cache: 8 MiB"]
        L3 [label="L3 Cache: 64 MiB"]
        CPU -> L1
        CPU -> L2
        CPU -> L3
    }
    
    subgraph cluster_mem {
        label="Memory"
        color=green
        RAM [label="125 GiB Total RAM\n(32 GiB Free)"]
    }

    System -> CPU
    System -> RAM
}
