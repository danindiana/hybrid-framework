digraph GDDR6X_Neon_Signaling {
    bgcolor="#0a0a0a";
    rankdir=LR;
    node [fontname="Courier New", fontcolor="#00ff00", color="#00ff00", style=filled, fillcolor="#001100", shape=record];
    edge [color="#00ffff", fontcolor="#00ffff", fontname="Courier New"];

    NRZ [label="{GDDR6|NRZ (2-Level)|1 Bit/Clock}", fillcolor="#111111", color="#888888", fontcolor="#888888"];
    PAM4 [label="{GDDR6X|PAM4 (4-Level)|2 Bits/Clock}", fillcolor="#002200", color="#00ff00", fontcolor="#00ff00"];

    Levels [label="{MODULATION LEVELS|{+3 | +1 | -1 | -3}}", fillcolor="#220022", color="#ff00ff", fontcolor="#ff00ff"];
    
    PAM4 -> Levels [label="PAM4_MAPPING"];
    
    Power [label="IDLE POWER BASELINE\nHigh precision required", shape=note, fillcolor="#222200", color="#ffff00", fontcolor="#ffff00"];
    PAM4 -> Power [style=dotted];
}
