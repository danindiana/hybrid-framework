digraph G {
    rankdir=LR;
    node [shape=box, style=filled, fillcolor=lightblue];

    subgraph cluster_lan {
        label = "Local Area Network (192.168.1.0/24)";
        style=dashed;

        cam [label="Hikvision Camera\n(192.168.1.64)", fillcolor=gold];
        rpi [label="Raspberry Pi 4 (Relay Node)\n(192.168.1.165)\ngo2rtc + Nginx", fillcolor=lightgreen];
        worlock [label="Worlock Desktop\nffmpeg recorder", fillcolor=orange];
    }

    cam -> rpi [label="RTSP (Single Feed)"];
    rpi -> worlock [label="RTSP Relay"];
    rpi -> "Client Browser" [label="WebRTC / HLS"];
}
