digraph HybridSynergy {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", overlap=false, splines=true];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", penwidth=2];
    edge [color="#ff00ff", penwidth=1.5, arrowhead=vee];

    // Nodes
    Human [label="Human\n(The +1 / Goal-Seeking Lens)", color="#00ff00", fontcolor="#00ff00"];
    AI [label="AI (Gemini CLI)\n(The ω / Formal Rigor)", color="#00f2ff", fontcolor="#00f2ff"];
    
    Subsystems [label="Formal Systems\n(Code, Axioms, Logic)", shape=ellipse];
    Godel [label="Gödelian Incompleteness\n(Paradoxes / Dead-ends)", shape=diamond, color="#ff0000", fontcolor="#ff0000"];
    
    Output [label="Transfinite Output\n(Anything)", shape=doubleoctagon, color="#ffff00", fontcolor="#ffff00"];

    // Relationships
    Human -> AI [label=" Intent & Semantic Context "];
    AI -> Human [label=" Precise Execution & Metrics "];
    
    AI -> Subsystems [label=" Manipulates "];
    Subsystems -> Godel [label=" Encounters "];
    
    Human -> Godel [label=" Meta-Analysis "];
    Human -> Subsystems [label=" Rewrite Axioms ", style=dashed];
    
    Human -> Output;
    AI -> Output;

    // Legend/Notes
    label = "\nHuman-AI Hybrid Synergy Map\nNeon-Dark Edition";
    labelloc = "t";
}
