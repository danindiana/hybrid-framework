digraph ModPrism {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    DOT [label="DOT Graph Data"];
    Prism [label="The Prism\n(Visual Refraction)", shape=invhouse, color="#00f2ff"];
    ThreeJS [label="WebGL 3D Engine", shape=ellipse];
    InteractiveViz [label="Explorable 3D Arch", shape=doubleoctagon, color="#ff00ff"];

    DOT -> Prism;
    Prism -> ThreeJS;
    ThreeJS -> InteractiveViz;
    
    label = "M2.4: Module C - The Prism (Visual Refraction)";
}
