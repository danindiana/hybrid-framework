digraph PropMultiAgent {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Gemini [label="Gemini Agent (Lead)", color="#00ff00"];
    Claude [label="Claude Agent (Support)", color="#00f2ff"];
    
    Consensus [label="Consensus Engine\n(COORD.md Logic)", shape=diamond, color="#ffff00"];
    
    UnifiedPath [label="Negotiated Implementation", shape=doubleoctagon, color="#00ff00"];

    Gemini -> Consensus [label=" Proposal A "];
    Claude -> Consensus [label=" Proposal B "];
    Consensus -> UnifiedPath [label=" Convergence "];
    
    label = "P1.2: Multi-Agent Hive Coordination";
}
