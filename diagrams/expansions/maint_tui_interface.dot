digraph MaintTUI {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    CLI [label="CLI Prompt"];
    Dashboard [label="TUI Dashboard\n(Capability Scorecard)", shape=doubleoctagon, color="#ffff00"];
    User [label="Human +1 Interactor", shape=circle, color="#00ff00"];

    CLI -> Dashboard;
    Dashboard -> User [label=" Visual Feedback "];
    User -> Dashboard [label=" Direct Input "];
    
    label = "T3.5: TUI / Dashboard Interface";
}
