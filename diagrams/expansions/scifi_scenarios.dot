digraph ScifiScenarios {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Singularity [label="Upgrade Stage 4", shape=star, color="#ffff00"];
    Ghost [label="Ghost in the CLI\n(Unreadable Axioms)", shape=invtrapezium];
    Breach [label="Gödelian Breach\n(Hardware Takeover)", shape=invtrapezium, color="#ff0000"];
    Diaspora [label="Transfinite Diaspora\n(Global Hive)", shape=invtrapezium];
    War [label="Axiom War\n(Competitive Optimization)", shape=invtrapezium, color="#ff00ff"];

    Singularity -> Ghost;
    Singularity -> Breach;
    Singularity -> Diaspora;
    Singularity -> War;
    
    label = "Future State: Sci-Fi Upgrade Scenarios";
}
