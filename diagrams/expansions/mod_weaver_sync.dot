digraph ModWeaver {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    RepoA [label="Hybrid Instance A"];
    RepoB [label="Hybrid Instance B"];
    Weaver [label="The Weaver\n(Synergy Sync)", shape=gear, color="#00ff00"];
    SharedHeuristics [label="Global Meta-Heuristics", shape=cylinder, color="#ffff00"];

    RepoA -> Weaver;
    RepoB -> Weaver;
    Weaver -> SharedHeuristics;
    SharedHeuristics -> RepoA [style=dashed];
    SharedHeuristics -> RepoB [style=dashed];
    
    label = "M2.3: Module B - The Weaver (Cross-Repo Synergy)";
}
