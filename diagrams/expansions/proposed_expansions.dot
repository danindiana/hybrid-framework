digraph ProposedExp {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Current [label="Hybrid Framework v1.0", shape=doubleoctagon, color="#00ff00"];
    Hive [label="Multi-Agent Hive", color="#ffff00"];
    VRAMHUD [label="Real-time VRAM HUD", color="#00f2ff"];
    GitHooks [label="Semantic Git Hooks", color="#00f2ff"];
    AutoAxiom [label="Auto Axiom Synthesis", color="#ffff00", penwidth=2];

    Current -> Hive;
    Current -> VRAMHUD;
    Current -> GitHooks;
    Current -> AutoAxiom;
    
    label = "Future State: Proposed Expansions";
}
