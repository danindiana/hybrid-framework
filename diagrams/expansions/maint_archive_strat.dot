digraph MaintArchive {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    ActiveLogs [label="Current Logs (>30 days)", color="#ffff00"];
    ArchiveJob [label="Archive Strategy", shape=diamond];
    Storage [label="/archive/ (Compressed)", shape=folder, color="#00ff00"];
    Prune [label="Delete Redundant Assets", shape=circle, color="#ff0000"];

    ActiveLogs -> ArchiveJob;
    ArchiveJob -> Storage [label=" Move "];
    ArchiveJob -> Prune [label=" Cleanup "];
    
    label = "T3.4: Automated Archiving Strategy";
}
