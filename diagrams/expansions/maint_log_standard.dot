digraph MaintLogStandard {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    RawLog [label="Mixed JSON Logs"];
    Format [label="Standardize Timestamps\n(ISO-8601)", shape=parallelogram, color="#ffff00"];
    ValidatedLog [label="Clean Forensic Data", shape=note, color="#00ff00"];

    RawLog -> Format;
    Format -> ValidatedLog;
    
    label = "T3.3: Log Standardization & Normalization";
}
