digraph AutSkill {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Trigger [label="Human Directive", shape=cds];
    Command [label="activate_skill", color="#00ff00"];
    Response [label="Injected Guidance", shape=note];
    Power [label="Augmented Agent", shape=doubleoctagon, color="#ffff00"];

    Trigger -> Command;
    Command -> Response;
    Response -> Power;
    
    label = "I.4.3: Skill Activation Trigger";
}
