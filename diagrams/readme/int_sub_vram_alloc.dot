digraph SubVRAM {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Total [label="Total VRAM (16GB)"];
    System [label="OS / Display Buffer"];
    ModelSpace [label="Model KV Cache", color="#ffff00"];
    Free [label="Available Overhead", color="#00ff00"];

    Total -> System;
    Total -> ModelSpace;
    Total -> Free;
    
    label = "I.2.4: VRAM Allocation Logic";
}
