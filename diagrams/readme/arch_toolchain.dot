digraph ArchToolchain {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    CLI [label="Gemini CLI\n(Orchestrator)", color="#00ff00", penwidth=2];
    Git [label="Git / Gh CLI\n(Sync)"];
    Viz [label="Graphviz (dot)\n(Visualization)"];
    Ollama [label="Ollama\n(Inference)"];

    CLI -> Git;
    CLI -> Viz;
    CLI -> Ollama;
    
    label = "S1.5: Hybrid Toolchain Integration";
}
