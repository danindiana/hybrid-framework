digraph CoordMemory {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Session [label="Active Session"];
    SharedMem [label="Shared Memory Tier\n(GEMINI.md / MEMORY.md)", shape=cylinder, color="#ffff00"];
    GlobalMem [label="Global Personal Memory\n(~/.gemini/GEMINI.md)", shape=cylinder, color="#00ff00"];

    Session -> SharedMem [label=" Fact Ingestion "];
    SharedMem -> GlobalMem [label=" Cross-Project Sync "];
    GlobalMem -> Session [label=" Preference Loading "];
    
    label = "S3.2: Multi-Tiered Memory Hierarchy";
}
