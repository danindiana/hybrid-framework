digraph AutHouse {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    OldFiles [label="Legacy Tmp Files"];
    Cron [label="House-keeping Job", shape=timer, color="#ffff00"];
    Clean [label="Workspace Sanitization", color="#00ff00"];

    OldFiles -> Cron;
    Cron -> Clean;
    
    label = "I.4.2: Repository House-keeping";
}
