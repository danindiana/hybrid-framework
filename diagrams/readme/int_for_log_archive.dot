digraph ForArchive {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Live [label="Active Forensics"];
    Scheduler [label="30-Day Trigger", shape=circle, color="#ffff00"];
    Archive [label="Compressed Store", shape=folder, color="#00ff00"];

    Live -> Scheduler;
    Scheduler -> Archive [label=" Migrate "];
    
    label = "I.3.3: Forensic Log Archiving";
}
