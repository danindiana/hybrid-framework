digraph ArchModelMgmt {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Pool [label="Available Models\n(Qwen, Gemma, DeepSeek)", shape=folder];
    Loader [label="Ollama Loader\n(MAX_LOADED=1)", shape=diamond, color="#ffff00"];
    VRAM [label="Active VRAM Slot", color="#00ff00", penwidth=3];
    Swap [label="Model Swap\n(Unload/Load)", shape=cds];

    Pool -> Loader;
    Loader -> VRAM [label=" Direct Map "];
    VRAM -> Swap [label=" Threshold Reached "];
    Swap -> Pool;
    
    label = "S1.2: Model & VRAM Management Logic";
}
