digraph SinCore {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Controller [label="Controller TUI"];
    Substrates [label="Agent Foundations"];
    Fusion [label="KINETIC CORE FUSION", shape=star, color="#ffffff", penwidth=4];

    Controller -> Fusion;
    Substrates -> Fusion;
    
    label = "I.5.1: Kinetic Core Fusion";
}
