digraph LifeP5Finalize {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Elegant [label="Final Artifact"];
    Docs [label="Session Logs / Visuals", shape=folder];
    Sync [label="Git Sync (master)", color="#00ff00", penwidth=2];
    Release [label="System State +1", shape=star, color="#ffff00"];

    Elegant -> Docs;
    Docs -> Sync;
    Sync -> Release;
    
    label = "S2.5: Phase 5 - Finalization & Sync";
}
