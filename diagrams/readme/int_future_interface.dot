digraph IntFutureOS {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Controller [label="Current Python TUI"];
    Stage2 [label="Hybrid Integrated HUD", color="#ffff00"];
    Stage3 [label="Pure Semantic Interface", color="#00ff00", shape=star, penwidth=3];

    Controller -> Stage2 [label=" Tool Fusion "];
    Stage2 -> Stage3 [label=" Axiom Dissolution "];
    
    label = "I5: Evolution of the Hybrid Interface";
}
