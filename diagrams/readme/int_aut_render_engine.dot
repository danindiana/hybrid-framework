digraph AutRender {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Files [label="*.dot Files", shape=note];
    Find [label="Recursive Find", shape=parallelogram];
    Engine [label="Graphviz Engine", shape=gear, color="#ffff00"];
    Renders [label="SVG / PNG", color="#00ff00"];

    Files -> Find;
    Find -> Engine;
    Engine -> Renders;
    
    label = "I.4.1: Recursive Render Engine";
}
