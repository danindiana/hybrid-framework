digraph EvolKnowledge {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Session [label="Session Experience"];
    Extraction [label="Fact Extraction", shape=parallelogram];
    GEMINI_MD [label="GEMINI.md\n(Shared Instruction)", shape=note, color="#00ff00"];
    SOP [label="methodology/SOP.md\n(Workflow Refinement)", shape=note, color="#ffff00"];

    Session -> Extraction;
    Extraction -> GEMINI_MD [label=" Convention "];
    Extraction -> SOP [label=" Optimization "];
    
    label = "S5.4: Knowledge Distillation & Persistence";
}
