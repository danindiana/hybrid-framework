digraph EvolFuture {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Current [label="Hybrid Framework v1.0"];
    Expansion [label="Continuous Visual Expansion", color="#ffff00"];
    ToolGrowth [label="Autonomous Tool Creation", color="#00ff00"];
    Maturity [label="Mature Transfinite OS", shape=doubleoctagon, color="#00f2ff", penwidth=4];

    Current -> Expansion;
    Current -> ToolGrowth;
    Expansion -> Maturity;
    ToolGrowth -> Maturity;
    
    label = "S5.5: Future-State Vision";
}
