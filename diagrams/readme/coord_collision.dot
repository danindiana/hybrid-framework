digraph CoordCollision {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    TaskA [label="Task A (Network Edit)"];
    TaskB [label="Task B (System Reboot)"];
    
    Lock [label="COORD.md 'LOCK' Status", shape=diamond, color="#ff0000"];
    
    Safety [label="Safety Delay / Coordination", shape=circle, color="#ffff00"];

    TaskA -> Lock;
    TaskB -> Lock;
    Lock -> Safety [label=" Conflict Detected "];
    Safety -> TaskB [label=" Resume After Release "];
    
    label = "S3.3: Collision Avoidance & Safety Protocol";
}
