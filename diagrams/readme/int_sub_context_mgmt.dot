digraph SubContext {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    RawContext [label="Raw Conversation History"];
    Compressor [label="Semantic Compressor", shape=diamond, color="#ffff00"];
    ActiveWindow [label="Active Context Window", shape=cylinder, color="#00ff00"];
    Discard [label="Legacy Buffer", color="#ff0000"];

    RawContext -> Compressor;
    Compressor -> ActiveWindow [label=" Retain "];
    Compressor -> Discard [label=" Prune "];
    
    label = "I.2.3: Context Window Management";
}
