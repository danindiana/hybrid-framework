digraph ArchContext {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Host [label="Host System\n(Linux)", color="#00ff00"];
    Docker [label="Docker Engine", shape=cylinder];
    OllamaSrv [label="Ollama Server", color="#ffff00"];
    GPUs [label="Dual GPUs\n(VRAM (~8GB/ea))", shape=box3d, color="#ff00ff"];
    
    Host -> Docker;
    Docker -> OllamaSrv;
    OllamaSrv -> GPUs [label=" Model Loading "];
    
    label = "S1.1: Physical & Virtual Architecture";
}
