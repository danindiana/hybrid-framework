digraph ForMetric {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Log [label="Raw Text Output"];
    Regex [label="Grep/Awk Filter", shape=diamond, color="#ffff00"];
    Data [label="Extracted Integers", color="#00ff00"];
    JSON [label="forensics.json", shape=note];

    Log -> Regex;
    Regex -> Data;
    Data -> JSON;
    
    label = "I.3.2: Metric Extraction Architecture";
}
