digraph AutSync {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Changes [label="Local Changes"];
    Git [label="git commit", shape=cds];
    Push [label="git push", shape=cds];
    GitHub [label="Remote Repo", shape=cloud, color="#ffff00"];

    Changes -> Git;
    Git -> Push;
    Push -> GitHub;
    
    label = "I.4.2: Git Sync Automation";
}
