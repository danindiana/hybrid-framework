digraph ForenMetrics {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Duration [label="Total Duration"];
    Tokens [label="Eval Count\n(Total Tokens)"];
    Rate [label="Eval Rate\n(Tokens/Sec)", color="#00ff00", penwidth=2];
    
    Efficiency [label="Technical Efficiency Score", shape=doubleoctagon, color="#ffff00"];

    Duration -> Efficiency;
    Tokens -> Efficiency;
    Rate -> Efficiency;
    
    label = "S4.2: Performance Metric Mapping";
}
