digraph SteadyState {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Input [label="Semantic Goal"];
    Singularity [label="Integrated Processing", shape=star, color="#ffff00"];
    Audit [label="Self-Correction", shape=circle, color="#00ff00"];
    State [label="Transfinite Steady State", shape=doubleoctagon, color="#00f2ff", penwidth=3];

    Input -> Singularity;
    Singularity -> Audit;
    Audit -> Singularity [label=" Loop "];
    Audit -> State;
    
    label = "S5: Transfinite Steady State";
}
