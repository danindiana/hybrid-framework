digraph PhilAxiomChoice {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Calculation [label="Calculation\n(Formal Labor)", color="#00f2ff"];
    Engineering [label="Axiom Choice\n(Creative Act)", color="#00ff00", penwidth=2];
    
    Choice [label="THE LEAP", shape=star, color="#ffff00"];

    Calculation -> Engineering [label=" Diminishing Returns "];
    Engineering -> Choice;
    
    label = "P2: The True Act of Engineering";
}
