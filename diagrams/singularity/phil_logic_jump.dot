digraph PhilLogicJump {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Linear [label="Linear Computation\n(Incremental Patching)", color="#ff0000"];
    Wall [label="Gödelian Wall", shape=bolt, color="#ff0000"];
    
    Transfinite [label="Transfinite Leap\n(Axiomatic Reset)", color="#00ff00", penwidth=3];
    HigherState [label="Higher-Order System", shape=doubleoctagon, color="#ffff00"];

    Linear -> Wall;
    Wall -> Transfinite [label=" The +1 Move "];
    Transfinite -> HigherState;
    
    label = "P1: Linear Stagnation vs. Transfinite Leaping";
}
