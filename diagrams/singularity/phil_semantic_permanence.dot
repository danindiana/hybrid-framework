digraph PhilSemanticPermanence {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Syntax1 [label="Syntax A\n(Old Code)", color="#ff0000"];
    Syntax2 [label="Syntax B\n(New Code)", color="#00f2ff"];
    
    Intent [label="ETERNAL INTENT\n(The 'Why')", shape=cylinder, color="#00ff00", penwidth=3];

    Syntax1 -> Intent [dir=back, label=" Expresses "];
    Syntax2 -> Intent [dir=back, label=" Expresses (High-Res) "];
    Syntax1 -> Syntax2 [label=" Dissolution ", style=dashed];
    
    label = "P3: Semantic Permanence through Morphing Syntax";
}
