digraph DiminishingReturns {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Effort [label="Formal Optimization Effort"];
    Improvement [label="Functional Improvement", color="#00ff00"];
    Saturation [label="Asymptotic Saturation", shape=circle, color="#ff0000"];

    Effort -> Saturation [label=" Logarithmic "];
    Saturation -> Improvement [label=" Zero Delta "];
    
    label = "T8.2: Diminishing Returns (Formal Stagnation)";
}
