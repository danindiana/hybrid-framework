digraph MetaConservation {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Objective [label="Semantic Objective", color="#00ff00", penwidth=2];
    Implementation1 [label="Implementation v1\n(Axioms A)", color="#00f2ff"];
    Implementation2 [label="Implementation v2\n(Axioms B)", color="#00f2ff"];
    
    Objective -> Implementation1;
    Objective -> Implementation2 [label=" Conserved Meaning "];
    Implementation1 -> Implementation2 [label=" Discarded Syntax ", style=dashed, color="#ff0000"];
    
    label = "T6.3: Semantic Conservation across Axiom Shifts";
}
