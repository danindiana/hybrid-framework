digraph SemanticProof {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Artifact [label="Formal Artifact"];
    Review [label="Human Review (+1)", color="#00ff00"];
    IntentMatch [label="Intent Alignment Check", shape=diamond, color="#ffff00"];
    SemanticProof [label="Semantic Verification", shape=doubleoctagon, color="#00ff00"];

    Artifact -> Review;
    Review -> IntentMatch;
    IntentMatch -> SemanticProof [label=" Validated "];
    
    label = "T10.2: Semantic Verification (+1 Check)";
}
