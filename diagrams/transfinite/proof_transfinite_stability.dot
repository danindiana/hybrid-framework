digraph TransfiniteStability {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Chaos [label="Entropy / Complexity", color="#ff0000"];
    Framework [label="Transfinite Methodology", shape=trapezium, color="#00ff00"];
    Stability [label="Transfinite Stability", shape=doubleoctagon, color="#ffff00", penwidth=4];

    Chaos -> Framework;
    Framework -> Stability [label=" Order Creation "];
    Stability -> Chaos [label=" Resilience ", style=dotted];
    
    label = "T10.5: Transfinite Stability & Order";
}
