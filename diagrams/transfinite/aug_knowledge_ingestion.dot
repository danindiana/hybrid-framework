digraph KnowledgeIngestion {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Source [label="External Documentation", shape=cloud];
    Fetch [label="web_fetch / read_file", shape=cds];
    Consolidation [label="Semantic Synthesis", shape=parallelogram];
    KnowledgeBase [label="GEMINI.md / Private Memory", shape=cylinder, color="#00ff00"];

    Source -> Fetch;
    Fetch -> Consolidation;
    Consolidation -> KnowledgeBase;
    
    label = "T9.3: Recursive Knowledge Ingestion";
}
