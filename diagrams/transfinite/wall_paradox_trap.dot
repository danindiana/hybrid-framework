digraph ParadoxTrap {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Bug [label="Circular Dependency"];
    Fix [label="Linear Patch"];
    RecursiveBug [label="New Circular State", color="#ff0000"];

    Bug -> Fix;
    Fix -> RecursiveBug;
    RecursiveBug -> Bug [label=" Infinite Loop "];
    
    label = "T8.3: The Paradox Trap (Formal Oscillation)";
}
