digraph AxiomConflict {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    OldAxiom [label="Axiom A\n(The Past)", color="#ff0000"];
    NewAxiom [label="Axiom B\n(The Future)", color="#00ff00"];
    Collision [label="Structural Friction", shape=bolt];
    Resolution [label="Axiom Substitution", shape=parallelogram, color="#ffff00"];

    OldAxiom -> Collision;
    NewAxiom -> Collision;
    Collision -> Resolution;
    
    label = "T7.1: Axiom Conflict & Resolution";
}
