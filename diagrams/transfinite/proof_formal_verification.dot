digraph FormalProof {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Code [label="Candidate Code"];
    Linters [label="Static Analysis"];
    Tests [label="Unit/Integration Tests"];
    FormalProof [label="Formal Verification (ω)", shape=doubleoctagon, color="#00f2ff"];

    Code -> Linters;
    Linters -> Tests;
    Tests -> FormalProof;
    
    label = "T10.1: Formal Proof (ω Verification)";
}
