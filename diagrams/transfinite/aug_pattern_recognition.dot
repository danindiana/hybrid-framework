digraph PatternRecognition {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    History [label="Session History"];
    Analyzer [label="Heuristic Analyzer", shape=diamond, color="#ffff00"];
    Patterns [label="Success Patterns", shape=parallelogram, color="#00ff00"];
    RefinedFramework [label="Optimized SOP", shape=doubleoctagon, color="#00f2ff"];

    History -> Analyzer;
    Analyzer -> Patterns;
    Patterns -> RefinedFramework [label=" Codification "];
    
    label = "T9.4: Heuristic Pattern Recognition";
}
