digraph MultiAgentProof {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Gemini [label="Gemini (ω-1)"];
    Claude [label="Claude (ω-2)"];
    Ollama [label="Local (ω-3)"];
    
    Consensus [label="Agent Consensus", shape=doubleoctagon, color="#ffff00"];

    Gemini -> Consensus;
    Claude -> Consensus;
    Ollama -> Consensus;
    
    label = "T10.3: Multi-Agent Consensus Verification";
}
