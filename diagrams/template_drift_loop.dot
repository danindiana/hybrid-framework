digraph TemplateDriftLoop {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Objective [label="Stated Goal\n(The 'Why')", color="#00ff00", fontcolor="#00ff00"];
    Code [label="Technical Artifact\n(The 'How')", color="#00f2ff"];
    
    DriftDoc [label="drift_analysis.md\n(Detection)", shape=note, color="#ffff00", fontcolor="#ffff00", penwidth=2];
    Intervention [label="Human Course Correction\n(Meta-Leap)", shape=parallelogram, color="#ff00ff"];
    
    Refinement [label="Refined Artifact", shape=doubleoctagon, color="#00ff00", fontcolor="#00ff00"];

    Objective -> DriftDoc [label=" Expectation "];
    Code -> DriftDoc [label=" Reality "];
    
    DriftDoc -> Intervention [label=" Identifies Gap "];
    Intervention -> Refinement [label=" Modifies Logic "];
    Refinement -> Objective [label=" Matches ", style=dashed];
    
    label = "Template Visualization: The Semantic Drift Correction Loop";
}
