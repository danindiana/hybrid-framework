digraph FutureStatic {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A3.5: Static Compilation Pipeline"];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica"];
        edge [color="#ff00ff", arrowhead=vee];

        Build_Harness [label="Compilation Engine"];
        Static_Link [label="Static Linking Flags\n(-static -static-libgcc)", shape=parallelogram];
        Static_Binary [label="Self-Contained Binaries\n(Zero dynamic dependencies)", color="#00ff00"];
        Docker [label="Distroless/Scratch Containers\n(Minimizes OS attack surface)", color="#ffff00"];

        Build_Harness -> Static_Link;
        Static_Link -> Static_Binary;
        Static_Binary -> Docker;
    }