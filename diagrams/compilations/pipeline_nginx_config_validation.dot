digraph PipeNginxVal {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A5.2: Nginx Configuration Validation Pipeline"];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica"];
        edge [color="#ff00ff", arrowhead=vee];

        Config_Change [label="Edit Nginx Configurations\n(/etc/nginx/sites-available/*)"];
        Syntax_Check [label="nginx -t\n(Configuration Syntax Check)", color="#ffff00"];
        Check_Result [label="Validation Status Check", shape=diamond];
        Reload_Service [label="systemctl reload nginx\n(Graceful Apply)", color="#00ff00"];
        Stop_Deploy [label="Abort Reload\n(Errors Blocked)", color="#ff0000"];

        Config_Change -> Syntax_Check;
        Syntax_Check -> Check_Result;
        Check_Result -> Reload_Service [label="Syntax Successful"];
        Check_Result -> Stop_Deploy [label="Syntax Errors Found"];
    }