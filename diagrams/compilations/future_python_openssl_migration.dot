digraph FuturePython {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A3.3: Python SSL Integration"];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica"];
        edge [color="#ff00ff", arrowhead=vee];

        Python_Build [label="Python Source Build\n(pyenv / custom build)"];
        SSL_Dir [label="--with-openssl=/usr/local/ssl", shape=parallelogram, color="#ffff00"];
        SSL_Module [label="import ssl\n(Loads OpenSSL 3.5.6)", color="#00ff00"];

        Python_Build -> SSL_Dir;
        SSL_Dir -> SSL_Module;
    }