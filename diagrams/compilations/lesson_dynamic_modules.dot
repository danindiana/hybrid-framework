digraph LessonModules {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A2.5: Nginx Dynamic Module Deconfliction Workflow", labelloc="t", fontsize=16];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica", fontsize=10];
        edge [color="#ff00ff", arrowhead=vee, fontname="Helvetica", fontsize=9];

        subgraph cluster_nginx_conflict {
            label = "Module Load Conflict";
            color = "#ff0000";
            fontcolor = "#ff0000";
            Nginx_Config [label="nginx.conf\n(includes /etc/nginx/modules-enabled/*.conf)"];
            Legacy_Module [label="ngx_http_geoip2_module.so\n(Compiled for 1.18.0 - Hash 1018000)"];
            Mismatch_Error [label="nginx: [emerg] module version mismatch\n(Expected 1.30.2 - Hash 1030002)", color="#ff0000"];
            
            Nginx_Config -> Legacy_Module;
            Legacy_Module -> Mismatch_Error;
        }

        subgraph cluster_nginx_quarantine {
            label = "Quarantine / Deconfliction Action";
            color = "#00ff00";
            fontcolor = "#00ff00";
            Grep_Verification [label="sudo grep -r geoip\n(Verified geoip is unused in sites)"];
            Quarantine_Cmd [label="sudo mv modules-enabled/ /modules-disabled/"];
            Success_Check [label="nginx -t\n(Configuration Syntax Check successful)", color="#00ff00"];
            
            Grep_Verification -> Quarantine_Cmd;
            Quarantine_Cmd -> Success_Check;
        }

        Mismatch_Error -> Grep_Verification [label="Triggers triage"];
    }