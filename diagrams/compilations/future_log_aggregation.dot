digraph FutureLogs {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A3.4: Unified Log Security Aggregation"];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica"];
        edge [color="#ff00ff", arrowhead=vee];

        Nginx_Logs [label="Nginx Access & Error Logs\n(/var/log/nginx/*)"];
        SSHD_Logs [label="SSH Daemon Logs\n(Systemd Journal)"];
        Fail2ban [label="Fail2ban Client Daemon", color="#ffff00"];
        IP_Bans [label="Uncomplicated Firewall (UFW)\n(IP Quarantine Rule)", color="#00ff00"];

        Nginx_Logs -> Fail2ban [label="Parses logs"];
        SSHD_Logs -> Fail2ban [label="Parses logs"];
        Fail2ban -> IP_Bans [label="Applies iptables block"];
    }