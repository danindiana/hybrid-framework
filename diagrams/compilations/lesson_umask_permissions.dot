digraph LessonUmask {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A2.3: Restrictive Umask Triage Architecture", labelloc="t", fontsize=16];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica", fontsize=10];
        edge [color="#ff00ff", arrowhead=vee, fontname="Helvetica", fontsize=9];

        subgraph cluster_umask_logic {
            label = "Umask Bitwise Masking";
            color = "#ff0000";
            fontcolor = "#ff0000";
            Base_Perms [label="Directory Base: 777\nFile Base: 666"];
            Umask_Value [label="Umask Applied: 027\n(Masks Group write, World read/write/exec)"];
            Actual_Perms [label="Directory Actual: 750 (drwxr-x---)\nFile Actual: 640 (-rw-r-----)"];
            Base_Perms -> Umask_Value;
            Umask_Value -> Actual_Perms;
        }

        subgraph cluster_triage_actions {
            label = "Security Verification & Fixing";
            color = "#00ff00";
            fontcolor = "#00ff00";
            Denied_Access [label="User 'jeb' denied access\n(Shell lookup bypasses /usr/local/bin)"];
            Chmod_Cmd [label="sudo chmod -R go+rX\n(Adds read & dir execute bits)"];
            Fixed_Perms [label="Directory Fixed: 755 (drwxr-xr-x)\nFile Fixed: 644 (-rw-r--r--)"];
            
            Denied_Access -> Chmod_Cmd;
            Chmod_Cmd -> Fixed_Perms;
        }

        Actual_Perms -> Denied_Access [label="Creates blockage"];
    }