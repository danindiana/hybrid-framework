digraph FutureQUIC {
        graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff", label="A3.1: Future QUIC and HTTP/3 Pipeline"];
        node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22", fontname="Helvetica"];
        edge [color="#ff00ff", arrowhead=vee];

        HTTP3_Standard [label="HTTP/3 Protocol Stack"];
        Nginx_130 [label="Nginx 1.30.x Build"];
        Quiche [label="quiche / nghttp3\n(QUIC transport libraries)", color="#ffff00"];
        Secure_SSL [label="OpenSSL 3.5.x LTS\n(TLS 1.3 Handshake)", color="#00ff00"];

        HTTP3_Standard -> Nginx_130;
        Nginx_130 -> Quiche [label="Inject dynamic library"];
        Nginx_130 -> Secure_SSL [label="ALPN Support"];
    }