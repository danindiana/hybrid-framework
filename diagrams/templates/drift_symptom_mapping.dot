digraph DriftSymptom {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Bug [label="Formal Bug\n(Syntax/Runtime)", color="#ff0000"];
    Drift [label="Semantic Drift\n(Logic/Intent)", color="#ff00ff"];
    
    Mapping [label="Symptom Mapping", shape=parallelogram];
    RootCause [label="Axiom Failure", shape=doubleoctagon, color="#ffff00"];

    Bug -> Mapping;
    Drift -> Mapping;
    Mapping -> RootCause;
    
    label = "T4.3: Symptom Mapping Architecture";
}
