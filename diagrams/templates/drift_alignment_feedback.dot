digraph DriftFeedback {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Action [label="Implementation Update"];
    Review [label="Human Review (+1)", color="#00ff00"];
    Log [label="session_log.md", shape=note];
    Success [label="System Re-Aligned", shape=doubleoctagon, color="#00ff00"];

    Action -> Review;
    Review -> Log;
    Review -> Success;
    
    label = "T4.5: Alignment Feedback Loop";
}
