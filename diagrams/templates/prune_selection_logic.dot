digraph PruneLogic {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Input [label="Heuristic Data", shape=parallelogram];
    Decision [label="Human Choice (+1)", shape=diamond, color="#00ff00", penwidth=2];
    Justification [label="pruning_report.md", shape=note];
    Commitment [label="Formal Integration", color="#00f2ff"];

    Input -> Decision;
    Decision -> Justification [label=" Record Rational "];
    Decision -> Commitment [label=" Proceed "];
    
    label = "T3.4: Selection Logic & Justification";
}
