digraph PrunePromotion {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Draft [label="Unverified Code"];
    Pruned [label="Heuristically Pruned"];
    Elegant [label="Elegant (ω+1)", color="#00ff00", penwidth=3];
    Master [label="Production / Repo", shape=folder, color="#ffff00"];

    Draft -> Pruned;
    Pruned -> Elegant;
    Elegant -> Master;
    
    label = "T3.5: Promotion Path of Elegant Solutions";
}
