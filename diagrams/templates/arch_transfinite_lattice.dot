digraph KnowledgeLattice {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=point, color="#00f2ff"];
    edge [color="#00f2ff", arrowhead=none, alpha=0.5];

    subgraph cluster_lattice {
        label="Transfinite Knowledge Lattice";
        fontcolor="#00ff00";
        color="#161b22";
        n1; n2; n3; n4; n5;
        n1 -> n2; n2 -> n3; n3 -> n4; n4 -> n5; n1 -> n3; n2 -> n4; n3 -> n5;
    }

    Hub [label="The Semantic Core", shape=doubleoctagon, color="#ffff00", fontcolor="#ffff00"];
    
    Hub -> n1; Hub -> n2; Hub -> n3; Hub -> n4; Hub -> n5;
    
    label = "A5: Transfinite Knowledge Lattice Architecture";
}
