digraph PruneFilter {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Candidate [label="Code Candidate"];
    Complexity [label="Complexity Check", color="#ff0000"];
    Security [label="Security Audit", color="#ff0000"];
    Elegance [label="Elegance Check", color="#00ff00"];
    
    Pass [label="Accepted for Review", color="#00ff00", shape=doubleoctagon];

    Candidate -> Complexity;
    Candidate -> Security;
    Candidate -> Elegance;
    Complexity -> Pass;
    Security -> Pass;
    Elegance -> Pass;
    
    label = "T3.2: Heuristic Filtering Layers";
}
