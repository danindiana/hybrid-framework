digraph ObjGrounding {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    HumanTruth [label="Human Semantic Truth", color="#00ff00"];
    Encoding [label="Prompt Encoding", shape=cds];
    AIContext [label="AI Model Context", shape=cylinder];
    Validation [label="Grounding Verification", shape=circle];

    HumanTruth -> Encoding;
    Encoding -> AIContext;
    AIContext -> Validation;
    Validation -> HumanTruth [label=" Feedback "];
    
    label = "T1.3: Semantic Grounding Loop";
}
