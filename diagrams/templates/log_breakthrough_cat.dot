digraph LogBreakthrough {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Event [label="System Event", shape=diamond];
    Trivial [label="Standard Iteration"];
    Breakthrough [label="Axiom Shift / Leap", color="#ffff00", penwidth=2];
    Record [label="Templates/axiom_shift.md", shape=note, color="#00ff00"];

    Event -> Trivial [label=" Expected "];
    Event -> Breakthrough [label=" Transfinite "];
    Breakthrough -> Record;
    
    label = "T2.4: Breakthrough Categorization";
}
