digraph CapSignature {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    HumanStyle [label="Human Intuition Type", color="#00ff00"];
    AIModel [label="AI Formal Signature", color="#00f2ff"];
    
    Synthesis [label="Collaborative Signature", shape=doubleoctagon, color="#ffff00", penwidth=2];
    
    Profile [label="capability_report.md", shape=note];

    HumanStyle -> Synthesis;
    AIModel -> Synthesis;
    Synthesis -> Profile;
    
    label = "T5.2: Synergy Signature Synthesis";
}
