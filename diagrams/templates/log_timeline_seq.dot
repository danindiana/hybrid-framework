digraph LogTimeline {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    Grounding [label="1. Semantic Grounding"];
    Execution [label="2. Formal Execution"];
    Alignment [label="3. Alignment Check"];
    Pruning [label="4. Heuristic Pruning"];
    Finalize [label="5. Finalization"];

    Grounding -> Execution -> Alignment -> Pruning -> Finalize;
    
    label = "T2.1: Session Timeline Sequencing";
}
