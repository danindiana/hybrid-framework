digraph HeuristicPruning {
    graph [bgcolor="#0d1117", fontname="Helvetica", fontcolor="#00f2ff"];
    node [shape=box, style="filled,rounded", color="#00f2ff", fontcolor="#00f2ff", fillcolor="#161b22"];
    edge [color="#ff00ff", arrowhead=vee];

    SearchSpace [label="Infinite Solution Space", shape=cloud];
    Candidates [label="AI Generated\nN-Candidates", color="#00f2ff"];
    
    Aesthetics [label="Human Heuristics\n(Elegance, Simplicity)", shape=trapezium, color="#00ff00", fontcolor="#00ff00"];
    
    Optimal [label="The Elegant Solution", shape=doubleoctagon, color="#ffff00", fontcolor="#ffff00"];

    SearchSpace -> Candidates;
    Candidates -> Aesthetics;
    Aesthetics -> Optimal;
    
    label = "Aspect 4: Heuristic Pruning";
}
