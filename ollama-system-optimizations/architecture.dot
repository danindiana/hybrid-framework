digraph G {
    rankdir=LR;
    node [shape=record, style=filled, fontname="Verdana"];
    
    subgraph cluster_cpu {
        label = "AMD Ryzen 9 5950X (Dual CCD)";
        color = blue;
        CCD0 [label="CCD 0 (8 Cores) | L3 Cache (32MB)", fillcolor=lightblue];
        CCD1 [label="CCD 1 (8 Cores) | L3 Cache (32MB)", fillcolor=lightblue];
    }

    subgraph cluster_mem {
        label = "System RAM (128GB DDR4)";
        color = green;
        MemBus [label="{Memory Controller | Dual Channel Bus}", fillcolor=lightgreen];
    }

    subgraph cluster_gpu {
        label = "Multi-GPU Fabric";
        color = orange;
        RTX5080 [label="RTX 5080 (16GB)", fillcolor=orange];
        RTX3080 [label="RTX 3080 (10GB)", fillcolor=orange];
    }

    CCD0 -> MemBus [label="UMA (Default Delay)"];
    CCD1 -> MemBus [label="UMA (Default Delay)"];
    
    // Optimized path
    CCD0 -> CCD0 [label="NUMA Local (Fast)", color=red, penwidth=2];
    CCD1 -> CCD1 [label="NUMA Local (Fast)", color=red, penwidth=2];
    
    RTX5080 -> RTX3080 [label="P2P (10-Bit Tag)", color=purple, dir=both];
    MemBus -> RTX5080 [label="ReBAR", color=blue];
}
